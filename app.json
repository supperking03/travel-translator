{
  "expo": {
    "name": "Free Offline Translator",
    "slug": "travel-translator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.theluxenomad.freeofflinetranslator",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used for voice input translation",
        "NSCameraUsageDescription": "Used to take a photo and extract text for offline translation",
        "NSPhotoLibraryUsageDescription": "Used to choose a photo and extract text for offline translation",
        "NSPhotoLibraryAddUsageDescription": "Used when saving images picked for offline translation"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.theluxenomad.freeofflinetranslator",
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F172A"
        }
      ]
    ],
    "scheme": "travel-translator",
    "experiments": {
      "typedRoutes": true
    }
  }
}
